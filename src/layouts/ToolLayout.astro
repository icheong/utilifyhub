---
import BaseLayout from './BaseLayout.astro';
import tools from '../data/tools.json';

interface Props {
  tool: {
    slug: string;
    name: string;
    description: string;
    category: string;
    tags: string[];
    icon: string;
    dateAdded: string;
  };
}

const { tool } = Astro.props;
const adsenseId = 'ca-pub-XXXXXXXXXXXXXXXX';

const relatedTools = tools
  .filter(t => t.slug !== tool.slug)
  .map(t => ({
    ...t,
    score:
      (t.category === tool.category ? 3 : 0) +
      t.tags.filter(tag => tool.tags.includes(tag)).length,
  }))
  .sort((a, b) => b.score - a.score)
  .slice(0, 6);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": tool.name,
  "description": tool.description,
  "url": `https://utilifygrid.com/tools/${tool.slug}`,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "datePublished": tool.dateAdded,
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home",            "item": "https://utilifygrid.com" },
      { "@type": "ListItem", "position": 2, "name": tool.category,     "item": `https://utilifygrid.com/category/${tool.category}` },
      { "@type": "ListItem", "position": 3, "name": tool.name }
    ]
  }
};
---

<BaseLayout
  title={`${tool.name} – Free Online Tool | UtilifyGrid`}
  description={tool.description}
  canonicalUrl={`/tools/${tool.slug}`}
  ogType="website"
  structuredData={structuredData}
>
  <div style="max-width:80rem; margin:0 auto; padding:2rem 1rem 3rem;">

    <!-- Breadcrumb -->
    <nav style="font-size:0.85rem; color:var(--text-muted); margin-bottom:1.5rem;" aria-label="Breadcrumb">
      <ol style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap; list-style:none; padding:0; margin:0;">
        <li><a href="/" style="color:var(--text-secondary); text-decoration:none; transition:color 0.15s;" onmouseover="this.style.color='#1D4ED8';" onmouseout="this.style.color='var(--text-secondary)';">Home</a></li>
        <li style="color:var(--text-muted);">›</li>
        <li><a href={`/category/${tool.category}`} style="color:var(--text-secondary); text-decoration:none; text-transform:capitalize; transition:color 0.15s;" onmouseover="this.style.color='#1D4ED8';" onmouseout="this.style.color='var(--text-secondary)';">{tool.category.replace('-', ' ')}</a></li>
        <li style="color:var(--text-muted);">›</li>
        <li style="color:var(--text-primary); font-weight:500;">{tool.name}</li>
      </ol>
    </nav>

    <div style="display:grid; grid-template-columns:1fr; gap:2rem;" class="tl-grid">

      <!-- LEFT SIDEBAR -->
      <aside class="tl-sidebar-left">
        <div style="position:sticky; top:5.5rem; display:flex; flex-direction:column; gap:1.5rem;">

          <!-- Category nav -->
          <div style="background:var(--bg-surface); border:1.5px solid var(--border); border-radius:0.875rem; padding:1rem;">
            <h3 style="font-size:0.72rem; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.07em; margin-bottom:0.75rem;">Categories</h3>
            <nav style="display:flex; flex-direction:column; gap:0.25rem;">
              {(['calculators','converters','health','web-tools','estimators']).map(cat => (
                <a
                  href={`/category/${cat}`}
                  style={`display:block; padding:0.4rem 0.75rem; border-radius:0.5rem; font-size:0.85rem; text-decoration:none; text-transform:capitalize; transition:all 0.15s; ${tool.category === cat ? 'background:#EFF6FF; color:#1D4ED8; font-weight:600;' : 'color:var(--text-secondary);'}`}
                  class={tool.category === cat ? 'sidebar-cat-active' : 'sidebar-cat-link'}
                >
                  {cat.replace('-', ' ')}
                </a>
              ))}
            </nav>
          </div>

          <!-- Skyscraper ad -->
          <div style="display:flex; justify-content:center;">
            <ins class="adsbygoogle" style="display:inline-block;width:160px;height:600px;"
              data-ad-client={adsenseId} data-ad-slot="2345678901" aria-label="Advertisement"></ins>
          </div>
        </div>
      </aside>

      <!-- MAIN CONTENT -->
      <article class="tl-main">

        <!-- Tool title -->
        <div style="margin-bottom:1.5rem;">
          <div style="display:flex; align-items:center; gap:0.875rem;">
            <span style="font-size:2.5rem; line-height:1;">{tool.icon}</span>
            <div>
              <h1 style="font-family:'Sora',sans-serif; font-size:clamp(1.4rem,3vw,1.9rem); font-weight:700; color:var(--text-primary); margin:0 0 0.25rem;">{tool.name}</h1>
              <p style="font-size:0.9rem; color:var(--text-secondary); margin:0;">{tool.description}</p>
            </div>
          </div>
        </div>

        <!-- Tool workspace card -->
        <div class="tool-card-surface" style="border-radius:1rem; padding:1.5rem; margin-bottom:2rem;">
          <slot name="tool" />
        </div>

        <!-- Post-result ad -->
        <div style="display:flex; justify-content:center; margin-bottom:2rem;">
          <ins class="adsbygoogle" style="display:block;"
            data-ad-client={adsenseId} data-ad-slot="3456789012"
            data-ad-format="auto" data-full-width-responsive="true" aria-label="Advertisement"></ins>
        </div>

        <!-- How to use -->
        <div class="seo-section" style="margin-bottom:1.5rem;">
          <slot name="how-to-use" />
        </div>

        <!-- How it works -->
        <div class="seo-section-alt" style="margin-bottom:1.5rem;">
          <slot name="how-it-works" />
        </div>

        <!-- FAQ -->
        <div style="margin-bottom:2rem;">
          <slot name="faq" />
        </div>

        <!-- Tags -->
        <div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:2rem;">
          {tool.tags.map(tag => (
            <span style="padding:0.2rem 0.75rem; background:var(--bg-surface-2); color:var(--text-secondary); border:1px solid var(--border); border-radius:999px; font-size:0.75rem; font-weight:500;">
              {tag}
            </span>
          ))}
        </div>

      </article>

      <!-- RIGHT SIDEBAR -->
      <aside class="tl-sidebar-right">
        <div style="position:sticky; top:5.5rem; display:flex; flex-direction:column; gap:1.5rem;">

          <!-- 300×250 ad -->
          <div style="display:flex; justify-content:center;">
            <ins class="adsbygoogle" style="display:inline-block;width:300px;height:250px;"
              data-ad-client={adsenseId} data-ad-slot="4567890123" aria-label="Advertisement"></ins>
          </div>

          <!-- Related tools -->
          <div style="background:var(--bg-surface); border:1.5px solid var(--border); border-radius:0.875rem; padding:1rem;">
            <h2 style="font-size:0.82rem; font-weight:700; color:var(--text-secondary); margin-bottom:0.75rem; text-transform:uppercase; letter-spacing:0.05em;">Related Tools</h2>
            <div style="display:flex; flex-direction:column; gap:0.25rem;">
              {relatedTools.map(related => (
                <a
                  href={`/tools/${related.slug}`}
                  class="related-tool-link"
                  style="display:flex; align-items:center; gap:0.75rem; padding:0.5rem 0.5rem; border-radius:0.5rem; text-decoration:none; transition:background 0.15s;"
                >
                  <span style="font-size:1.25rem; flex-shrink:0;">{related.icon}</span>
                  <span style="font-size:0.85rem; font-weight:500; color:var(--text-primary); line-height:1.3;">{related.name}</span>
                </a>
              ))}
            </div>
          </div>

          <!-- Second 300×250 ad -->
          <div style="display:flex; justify-content:center;">
            <ins class="adsbygoogle" style="display:inline-block;width:300px;height:250px;"
              data-ad-client={adsenseId} data-ad-slot="5678901234" aria-label="Advertisement"></ins>
          </div>

        </div>
      </aside>

    </div>

    <!-- More tools grid -->
    <div style="margin-top:3rem; padding-top:2.5rem; border-top:1px solid var(--border);">
      <h2 style="font-family:'Sora',sans-serif; font-size:1.1rem; font-weight:700; color:var(--text-primary); margin-bottom:1.25rem;">More Tools You Might Like</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(130px,1fr)); gap:0.875rem;">
        {relatedTools.map(related => (
          <a
            href={`/tools/${related.slug}`}
            class="tool-card-themed"
            style="display:flex; flex-direction:column; align-items:center; text-align:center; padding:1rem 0.75rem; text-decoration:none;"
          >
            <span style="font-size:1.75rem; margin-bottom:0.4rem;">{related.icon}</span>
            <span style="font-size:0.78rem; font-weight:600; color:var(--text-primary); line-height:1.3;">{related.name}</span>
          </a>
        ))}
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  /* Three-column grid layout */
  @media (min-width: 1024px) {
    .tl-grid {
      grid-template-columns: 160px 1fr 280px !important;
      grid-template-rows: auto;
    }
    .tl-sidebar-left  { display: block !important; }
    .tl-sidebar-right { display: block !important; }
  }

  .tl-sidebar-left,
  .tl-sidebar-right {
    display: none;
  }

  /* Tool workspace card — theme-aware */
  .tool-card-surface {
    background: var(--bg-surface);
    border: 1.5px solid var(--border);
    box-shadow: var(--shadow-card);
  }

  /* SEO content sections */
  .seo-section {
    background: var(--bg-surface);
    border: 1.5px solid var(--border);
    border-radius: 0.875rem;
    padding: 1.5rem;
  }
  .seo-section-alt {
    background: var(--bg-surface-2);
    border: 1.5px solid var(--border);
    border-radius: 0.875rem;
    padding: 1.5rem;
  }

  /* Sidebar category links hover */
  .sidebar-cat-link:hover {
    background: var(--bg-surface-2) !important;
    color: var(--text-primary) !important;
  }

  /* Dark mode: active category pill */
  :root.dark .sidebar-cat-active {
    background: rgba(29, 78, 216, 0.2) !important;
    color: #93C5FD !important;
  }

  /* Related tool links hover */
  .related-tool-link:hover {
    background: var(--bg-surface-2);
  }
  .related-tool-link:hover span:last-child {
    color: #1D4ED8;
  }
  :root.dark .related-tool-link:hover span:last-child {
    color: #60A5FA;
  }

  /* ── Dark mode overrides for tool page inline styles ─────────
     Tool pages use inline style= attributes with hardcoded light
     colours. These selectors override the most common ones.     */

  /* Generic white backgrounds inside tool workspace */
  :root.dark .tool-card-surface [style*="background:#fff"],
  :root.dark .tool-card-surface [style*="background: #fff"],
  :root.dark .tool-card-surface [style*="background:#FFFFFF"],
  :root.dark .tool-card-surface [style*="background: #FFFFFF"],
  :root.dark .tool-card-surface [style*="background: white"],
  :root.dark .seo-section      [style*="background:#fff"],
  :root.dark .seo-section      [style*="background:#FFFFFF"],
  :root.dark .seo-section-alt  [style*="background:#fff"],
  :root.dark .seo-section-alt  [style*="background:#FFFFFF"] {
    background: var(--bg-surface-3) !important;
    border-color: var(--border) !important;
  }

  /* Light surface backgrounds used for info rows / formula rows */
  :root.dark .tool-card-surface [style*="background:#F8FAFC"],
  :root.dark .tool-card-surface [style*="background: #F8FAFC"],
  :root.dark .tool-card-surface [style*="background:#F1F5F9"],
  :root.dark .seo-section       [style*="background:#F8FAFC"],
  :root.dark .seo-section-alt   [style*="background:#F8FAFC"] {
    background: var(--bg-surface-2) !important;
    border-color: var(--border) !important;
  }

  /* Dark text on light backgrounds — flip to theme variable */
  :root.dark .tool-card-surface [style*="color:#0F172A"],
  :root.dark .tool-card-surface [style*="color: #0F172A"],
  :root.dark .tool-card-surface [style*="color:#1E293B"],
  :root.dark .tool-card-surface [style*="color:#0f172a"],
  :root.dark .seo-section       [style*="color:#0F172A"],
  :root.dark .seo-section-alt   [style*="color:#0F172A"] {
    color: var(--text-primary) !important;
  }

  /* Mid-grey text — flip to theme secondary */
  :root.dark .tool-card-surface [style*="color:#475569"],
  :root.dark .tool-card-surface [style*="color:#64748B"],
  :root.dark .seo-section       [style*="color:#475569"],
  :root.dark .seo-section       [style*="color:#64748B"],
  :root.dark .seo-section-alt   [style*="color:#475569"],
  :root.dark .seo-section-alt   [style*="color:#64748B"] {
    color: var(--text-secondary) !important;
  }

  /* Light border colours */
  :root.dark .tool-card-surface [style*="border:1px solid #E2E8F0"],
  :root.dark .tool-card-surface [style*="border: 1px solid #E2E8F0"],
  :root.dark .tool-card-surface [style*="border:1.5px solid #E2E8F0"],
  :root.dark .seo-section       [style*="border:1px solid #E2E8F0"],
  :root.dark .seo-section-alt   [style*="border:1px solid #E2E8F0"] {
    border-color: var(--border) !important;
  }

  /* Input fields inside dark mode */
  :root.dark .tool-card-surface input,
  :root.dark .tool-card-surface textarea,
  :root.dark .tool-card-surface select {
    background: var(--bg-surface-2) !important;
    color: var(--text-primary) !important;
    border-color: var(--border) !important;
  }
  :root.dark .tool-card-surface input::placeholder,
  :root.dark .tool-card-surface textarea::placeholder {
    color: var(--text-muted) !important;
  }
  :root.dark .tool-card-surface input:focus,
  :root.dark .tool-card-surface textarea:focus,
  :root.dark .tool-card-surface select:focus {
    border-color: #3B82F6 !important;
    box-shadow: 0 0 0 3px rgba(59,130,246,0.15) !important;
  }

  /* FAQ cards */
  :root.dark .seo-section [style*="border:1.5px solid #E2E8F0"],
  :root.dark .seo-section [style*="border: 1.5px solid #E2E8F0"] {
    background: var(--bg-surface-2) !important;
    border-color: var(--border) !important;
  }

  /* Output/result readonly textareas (e.g. JSON→TS) */
  :root.dark .tool-card-surface textarea[readonly] {
    background: var(--bg-surface-3) !important;
  }

  /* Mode/toggle buttons in tool pages */
  :root.dark .tool-card-surface button[style*="background:#fff"],
  :root.dark .tool-card-surface button[style*="background: #fff"],
  :root.dark .tool-card-surface button[style*="background:#FFFFFF"] {
    background: var(--bg-surface-2) !important;
    border-color: var(--border) !important;
    color: var(--text-secondary) !important;
  }

  /* Options/settings rows */
  :root.dark .tool-card-surface [style*="background:#F8FAFC"][style*="border:1px"] {
    background: var(--bg-surface-2) !important;
    border-color: var(--border) !important;
  }

  /* Headings inside tool cards */
  :root.dark .tool-card-surface h2,
  :root.dark .tool-card-surface h3,
  :root.dark .seo-section h2,
  :root.dark .seo-section h3,
  :root.dark .seo-section-alt h2,
  :root.dark .seo-section-alt h3 {
    color: var(--text-primary) !important;
  }

  /* ── FAQ schema markup items ─── */
  :root.dark [itemtype*="Question"] {
    background: var(--bg-surface-2) !important;
    border-color: var(--border) !important;
  }
  :root.dark [itemtype*="Question"] h3 {
    color: var(--text-primary) !important;
  }
  :root.dark [itemtype*="Question"] p {
    color: var(--text-secondary) !important;
  }
</style>

<script>
  document.querySelectorAll('.adsbygoogle').forEach(() => {
    (window.adsbygoogle = window.adsbygoogle || []).push({});
  });
</script>
